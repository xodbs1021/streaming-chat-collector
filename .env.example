PORT=4010
HOST=127.0.0.1
PUBLIC_BASE_URL=http://localhost:4010
FRONTEND_ORIGIN=http://localhost:4010

# Register these in CHZZK Developers.
CHZZK_CLIENT_ID=
CHZZK_CLIENT_SECRET=
CHZZK_REDIRECT_URI=http://localhost:4010/api/auth/chzzk/callback

# Optional: used by /admin to show the default channel field value.
CHZZK_DEFAULT_CHANNEL_ID=
SOOP_DEFAULT_CHANNEL_ID=

# Local runtime chat archive.
CHAT_DATA_DIR=./data/chat-sessions
